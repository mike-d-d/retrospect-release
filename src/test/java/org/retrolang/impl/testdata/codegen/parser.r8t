_ = aoc1("L24\nL26\nR15")
return aoc1("L24\nL26\nR15\nR55\nL10\nR40\nR15")


function aoc1(input) {
  input = stream(input)
  oneLine = outputMatch(oneOf("LR")) + parseInt + choose(newLine, "")
  pos = 50
  for sequential pos, input {
    if peek(atEnd, input) { break }
    [dir, amt] = match(oneLine, input=)
    pos = (pos + (dir == "L"  ? -amt : amt)) % 100
    if pos == 0 { result << 1 }
  } collect {
    result =| count
  }
  return result
}

